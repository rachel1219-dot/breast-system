{
  "version": 2,
  "builds": [
    {
      "src": "test_app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)"
    },
    {
      "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|ico|svg|mp4|woff|woff2|ttf|eot))$"
    },
    {
      "src": "/(.*)",
      "dest": "test_app.py"
    }
  ]
}
