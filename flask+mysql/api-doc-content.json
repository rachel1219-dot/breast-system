      "type": "h2",
      "text": "2. 添加学生接口"
    },
    {
      "type": "h3",
      "text": "基本信息"
    },
    {
      "type": "table",
      "headers": ["字段", "值"],
      "rows": [
        ["接口名称", "添加学生"],
        ["请求方法", "GET/POST"],
        ["URL", "/add"],
        ["Content-Type", "application/x-www-form-urlencoded"]
      ]
    },
    {
      "type": "h3",
      "text": "请求参数"
    },
    {
      "type": "table",
      "headers": ["参数名", "类型", "必填", "说明"],
      "rows": [
        ["name", "string", "是", "学生姓名，最大50字符"],
        ["age", "integer", "是", "学生年龄，范围1-150"]
      ]
    },
    {
      "type": "h3",
      "text": "请求示例"
    },
    {
      "type": "code",
      "language": "html",
      "text": "<form method=\"POST\" action=\"/add\">\n  <input type=\"text\" name=\"name\" placeholder=\"姓名\">\n  <input type=\"number\" name=\"age\" placeholder=\"年龄\">\n  <button type=\"submit\">提交</button>\n</form>"
    },
    {
      "type": "h3",
      "text": "成功响应"
    },
    {
      "type": "code",
      "language": "text",
      "text": "HTTP 302 Redirect → / (返回列表页)"
    },
    {
      "type": "h3",
      "text": "后端代码"
    },
    {
      "type": "code",
      "language": "python",
      "text": "@app.route('/add', methods=['GET', 'POST'])\ndef add_student():\n    if request.method == 'POST':\n        name = request.form.get('name')\n        age = request.form.get('age')\n        # 验证数据...\n        student = Student(name=name, age=age)\n        db.session.add(student)\n        db.session.commit()\n        flash(f'添加成功！', 'success')\n        return redirect(url_for('index'))\n    return render_template('add.html')"
    },
    {
      "type": "pagebreak"
    },
    {
      "type": "h2",
