      "type": "table",
      "headers": ["字段", "值"],
      "rows": [
        ["接口名称", "编辑学生"],
        ["请求方法", "GET/POST"],
        ["URL", "/edit/<student_id>"],
        ["参数类型", "path (整数)"]
      ]
    },
    {
      "type": "h3",
      "text": "请求参数"
    },
    {
      "type": "table",
      "headers": ["参数名", "位置", "类型", "说明"],
      "rows": [
        ["student_id", "URL路径", "integer", "学生ID，主键"]
      ]
    },
    {
      "type": "h3",
      "text": "后端代码"
    },
    {
      "type": "code",
      "language": "python",
      "text": "@app.route('/edit/<int:student_id>', methods=['GET', 'POST'])\ndef edit_student(student_id):\n    student = Student.query.get_or_404(student_id)\n    if request.method == 'POST':\n        student.name = request.form.get('name')\n        student.age = request.form.get('age')\n        db.session.commit()\n        flash('更新成功！', 'success')\n        return redirect(url_for('index'))\n    return render_template('edit.html', student=student)"
    },
    {
      "type": "divider"
    },
    {
      "type": "h2",
      "text": "4. 删除学生接口"
    },
    {
      "type": "h3",
      "text": "基本信息"
    },
    {
      "type": "table",
      "headers": ["字段", "值"],
      "rows": [
        ["接口名称", "删除学生"],
        ["请求方法", "GET"],
        ["URL", "/delete/<student_id>"],
        ["注意", "建议使用POST或添加确认机制"]
      ]
    },
    {
      "type": "h3",
      "text": "后端代码"
    },
    {
      "type": "code",
      "language": "python",
      "text": "@app.route('/delete/<int:student_id>')\ndef delete_student(student_id):\n    student = Student.query.get_or_404(student_id)\n    db.session.delete(student)\n    db.session.commit()\n    flash(f'删除成功！', 'success')\n    return redirect(url_for('index'))"
    },
    {
      "type": "pagebreak"
    },
