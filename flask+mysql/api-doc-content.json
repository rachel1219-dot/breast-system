        ["age", "Integer", "NOT NULL", "学生年龄"],
        ["created_at", "DateTime", "DEFAULT NOW()", "创建时间"]
      ]
    },
    {
      "type": "code",
      "language": "python",
      "text": "class Student(db.Model):\n    __tablename__ = 'students'\n    \n    id = db.Column(db.Integer, primary_key=True, \n                   autoincrement=True)\n    name = db.Column(db.String(50), nullable=False)\n    age = db.Column(db.Integer, nullable=False)\n    created_at = db.Column(db.DateTime, default=datetime.now)"
    },
